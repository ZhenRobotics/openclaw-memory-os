*.test.ts
*.test.js
*.spec.ts
*.spec.js
coverage/
.nyc_output/
jest.config.*

# Examples (optional, keep for reference)
examples/

# Build artifacts (keep dist/)
out/
build/

# Documentation drafts (keep only core docs)
